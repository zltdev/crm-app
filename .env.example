# Supabase — public (expuestas al browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase — SERVER ONLY. Nunca prefijar con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# BasicAuth gate en middleware. Mientras esto esté seteado, toda la app pide login del browser.
# Para deshabilitarlo, dejalo vacío (no recomendado en prod).
APP_BASIC_AUTH_USER=zlt
APP_BASIC_AUTH_PASSWORD=
