# Supabase — public (expuestas al browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase — SERVER ONLY. Nunca prefijar con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Password única para acceder a la app (página /login).
# Podés seguir usando APP_BASIC_AUTH_PASSWORD si ya estaba seteada — el código lee ambas.
APP_PASSWORD=

# Secreto para firmar la cookie de sesión. Generá 32+ chars random.
# Podés usar `openssl rand -hex 32` o cualquier string largo aleatorio.
APP_SESSION_SECRET=
